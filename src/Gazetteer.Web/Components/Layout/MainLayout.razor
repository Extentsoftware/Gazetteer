@inherits LayoutComponentBase

<div class="d-flex flex-column min-vh-100">
    <nav class="navbar navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                <i class="bi bi-geo-alt-fill me-2"></i>EU & UK Gazetteer
            </a>
            <div class="d-flex">
                <a class="btn btn-outline-light btn-sm me-2" href="/">
                    <i class="bi bi-search me-1"></i>Search
                </a>
                <a class="btn btn-outline-light btn-sm" href="/chat">
                    <i class="bi bi-headset me-1"></i>Location Copilot
                </a>
            </div>
        </div>
    </nav>

    <main class="flex-grow-1">
        @Body
    </main>

    <footer class="bg-light text-muted text-center py-2 border-top">
        <small>EU & UK Gazetteer &mdash; Powered by OpenStreetMap data</small>
    </footer>
</div>
